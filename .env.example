# Supabase — quando preenchido, o app usa o backend real (auth + Postgres + RLS).
# Se ficar em branco, o app roda em modo demonstração com dados locais (localStorage).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# n8n — webhook para orquestração de automações (boas-vindas via WhatsApp/e-mail).
# Opcional no MVP; se vazio, os disparos são apenas simulados/logados.
VITE_N8N_WEBHOOK_URL=
